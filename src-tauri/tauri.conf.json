{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ParakeetSTT",
  "version": "0.1.0",
  "identifier": "cc.dodmcdund.parakeet-stt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "ParakeetSTT",
        "width": 320,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "capabilities": [
    {
      "identifier": "default",
      "description": "Default capabilities",
      "windows": ["main"],
      "permissions": [
        "core:default"
      ]
    }
  ],
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
